$("#resetBtn").onclick=()=>{
  if(!confirm("Réinitialiser la progression, les scores et la sélection ?"))return;
  Object.keys(storage).filter(k=>k.startsWith("allsp_")).forEach(k=>storage.removeItem(k));
  renderAll();updateProgress();
};

function renderAll(){
  renderHome();renderSubjects($("#subjectSearch")?.value||"");renderMyPath();renderQuizHub();renderSources();updateProgress();
  resetMystery();newMatch();newTf();updateAiContext();
}
renderAll();
</script>
