const AI_MODEL="Qwen2.5-0.5B-Instruct-q4f16_1-MLC";
let aiEngine=null;
let aiLoading=false;
let aiConversation=[];

function addAiMessage(role,text){
  const box=document.createElement("div");
  box.className=`ai-msg ${role}`;
  box.textContent=text;
  $("#aiChat").appendChild(box);
  $("#aiChat").scrollTop=$("#aiChat").scrollHeight;
  return box;
}
function setAiStatus(text,progress=null){
  $("#aiStatus").textContent=text;
  if(progress!==null){
    const value=Math.max(0,Math.min(100,Math.round(progress*100)));
    $("#aiProgressBar").style.width=value+"%";
  }
}
async function initLocalAi(){
  if(aiEngine)return true;
  if(aiLoading)return false;
  if(!("gpu" in navigator)){
    setAiStatus("WebGPU n’est pas disponible sur ce navigateur. Essaie une version récente de Chrome ou Edge.");
    addAiMessage("error","L’IA locale ne peut pas démarrer car WebGPU n’est pas disponible sur cet appareil.");
    return false;
  }
  aiLoading=true;
  $("#aiLoad").disabled=true;
  $("#aiAsk").disabled=true;
  setAiStatus("Chargement du moteur IA…",0.01);
  try{
    const webllm=await import("https://esm.run/@mlc-ai/web-llm@0.2.82");
    aiEngine=await webllm.CreateMLCEngine(AI_MODEL,{
      initProgressCallback:report=>{
        setAiStatus(report.text||"Téléchargement et préparation du modèle…",Number(report.progress)||0);
      }
    });
    setAiStatus("IA prête. Tes questions restent traitées dans ce navigateur.",1);
    addAiMessage("assistant","L’IA est prête. Pose ta question sur le chapitre ouvert.");
    $("#aiAsk").disabled=false;
    return true;
  }catch(err){
    console.error(err);
    aiEngine=null;
    setAiStatus("Impossible de charger l’IA locale sur cet appareil.");
    addAiMessage("error","Le modèle n’a pas pu être chargé. Vérifie la connexion, l’espace disponible et la compatibilité WebGPU, puis réessaie.");
    return false;
  }finally{
    aiLoading=false;
    $("#aiLoad").disabled=false;
  }
}
async function askLocalAi(){
  const question=$("#aiQuestion").value.trim();
  if(!question){alert("Écris d’abord ta question.");return}
  if(!aiEngine){
    const ready=await initLocalAi();
    if(!ready||!aiEngine)return;
  }

  const c=currentLearningContext;
  const modes={
    simple:"Explique avec des mots simples, une analogie claire et des étapes courtes.",
    example:"Donne un nouvel exemple guidé, différent de celui du cours, puis une petite question d’entraînement.",
    exercise:"Crée un exercice progressif. Pose une seule question et attends la réponse de l’élève avant de poursuivre.",
    correct:"Aide à repérer l’erreur de raisonnement sans donner immédiatement toute la solution."
  };
  const context=`Matière : ${c.subject||"non précisée"}
Chapitre : ${c.chapter||"non précisé"}
Résumé du cours : ${c.intro||"aucun"}
Notions clés : ${(c.points||[]).join(" | ")||"aucune"}`;

  addAiMessage("user",question);
  $("#aiQuestion").value="";
  $("#aiAsk").disabled=true;
  const waiting=addAiMessage("assistant","Je réfléchis…");

  try{
    const messages=[
      {
        role:"system",
        content:`Tu es un professeur patient de Première générale. Réponds uniquement en français. Sois exact, pédagogique et adapté à un lycéen. Utilise le contexte du cours fourni. Ne révèle pas de raisonnement interne caché : donne seulement une explication claire, les étapes utiles, les calculs vérifiables et les exemples nécessaires. ${modes[$("#aiMode").value]}`
      },
      {role:"user",content:`${context}\n\nQuestion de l’élève : ${question}`}
    ];
    const result=await aiEngine.chat.completions.create({
      messages,
      temperature:0.35,
      max_tokens:500
    });
    const answer=result?.choices?.[0]?.message?.content||"Je n’ai pas réussi à produire une réponse.";
    waiting.textContent=answer;
    aiConversation.push({question,answer});
  }catch(err){
    console.error(err);
    waiting.className="ai-msg error";
    waiting.textContent="Une erreur est survenue pendant la réponse. Réessaie avec une question plus courte.";
  }finally{
    $("#aiAsk").disabled=false;
    $("#aiChat").scrollTop=$("#aiChat").scrollHeight;
  }
}

