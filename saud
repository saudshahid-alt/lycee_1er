let quizQuestions=[],quizIndex=0,quizScore=0,quizAnswered=false,quizContext="";
function startChapterQuiz(sid,i){
  const s=subjectById(sid),c=s.chapters[i];
  quizQuestions=shuffle(questionsForChapter(s,i));quizIndex=0;quizScore=0;quizContext=chapterKey(sid,i);
  openQuiz(`${s.icon} ${s.short}`,c.title);
}
function startPathQuiz(){
  const ids=selectedIds();if(!ids.length)return;
  const pool=ids.flatMap(id=>{
    const s=subjectById(id);
    return s.chapters.flatMap((c,i)=>questionsForChapter(s,i).map(q=>({...q,label:s.short})));
  });
  quizQuestions=shuffle(pool).slice(0,10);quizIndex=0;quizScore=0;quizContext="path";
  openQuiz("Mes spécialités","Quiz global du parcours");
}
function openQuiz(label,title){
  $("#quizSubjectLabel").textContent=label;$("#quizTitle").textContent=title;
  $("#quizModal").classList.remove("hidden");renderQuizQuestion();
}
function renderQuizQuestion(){
  const q=quizQuestions[quizIndex];quizAnswered=false;
  $("#quizPosition").textContent=`Question ${quizIndex+1} / ${quizQuestions.length}`;
  $("#quizScore").textContent=`Score : ${quizScore}`;
  $("#quizQuestion").textContent=q.q;
  $("#quizExplain").classList.add("hidden");
  $("#quizNext").classList.add("hidden");$("#quizNext").dataset.action="next";
  $("#quizOptions").innerHTML=q.options.map((o,i)=>`<button class="option" data-answer="${i}">${esc(o)}</button>`).join("");
  $$(".option",$("#quizOptions")).forEach(b=>b.onclick=()=>answerQuiz(Number(b.dataset.answer),b));
}
function answerQuiz(i,button){
  if(quizAnswered)return;quizAnswered=true;
  const q=quizQuestions[quizIndex],buttons=$$(".option",$("#quizOptions"));
  buttons[q.answer].classList.add("correct");
  if(i===q.answer)quizScore++;else button.classList.add("wrong");
  $("#quizScore").textContent=`Score : ${quizScore}`;
  $("#quizExplain").innerHTML=`<b>Correction :</b> ${esc(q.explain)}`;
  $("#quizExplain").classList.remove("hidden");
  $("#quizNext").textContent=quizIndex===quizQuestions.length-1?"Voir le résultat":"Question suivante";
  $("#quizNext").classList.remove("hidden");
}
$("#quizNext").onclick=()=>{
  if($("#quizNext").dataset.action==="restart"){
    if(quizContext==="path")startPathQuiz();
    else{const [sid,...rest]=quizContext.split("-");startChapterQuiz(sid,Number(rest.join("-")))}
    return;
  }
  if(quizIndex<quizQuestions.length-1){quizIndex++;renderQuizQuestion();return}
  const pct=Math.round(quizScore/quizQuestions.length*100);
  $("#quizPosition").textContent="Terminé";$("#quizQuestion").textContent=`Résultat : ${quizScore} / ${quizQuestions.length}`;
  $("#quizOptions").innerHTML="";
  $("#quizExplain").innerHTML=`<div class="score-card">${pct} % — ${pct>=80?"Très bonne maîtrise.":pct>=60?"Bon début : relis les corrections.":"Reprends le cours puis recommence."}</div>`;
  $("#quizExplain").classList.remove("hidden");
  $("#quizNext").textContent="Recommencer";$("#quizNext").dataset.action="restart";
  if(quizContext!=="path"){
    const best=Math.max(quizScore,Number(storage.getItem("allsp_score_"+quizContext)||0));
    storage.setItem("allsp_score_"+quizContext,String(best));
  }
};
