const $=(s,r=document)=>r.querySelector(s);
const $$=(s,r=document)=>[...r.querySelectorAll(s)];
const storage=window.localStorage;
const esc=s=>String(s).replace(/[&<>"']/g,c=>({"&":"&amp;","<":"&lt;",">":"&gt;",'"':"&quot;","'":"&#039;"}[c]));
const shuffle=a=>[...a].sort(()=>Math.random()-.5);
const subjectById=id=>SUBJECTS.find(s=>s.id===id);
const chapterKey=(sid,i)=>sid+"-"+i;
let currentLearningContext={subject:"",chapter:"",intro:"",points:[]};

function showPage(id){
  $$(".page").forEach(p=>p.classList.toggle("active",p.id===id));
  $$(".nav").forEach(n=>n.classList.toggle("active",n.dataset.page===id));
  window.scrollTo({top:0,behavior:"smooth"});
}
$$(".nav").forEach(n=>n.onclick=()=>showPage(n.dataset.page));

const theme=storage.getItem("allsp_theme")||"light";
document.documentElement.dataset.theme=theme;
$("#themeBtn").onclick=()=>{
  const next=document.documentElement.dataset.theme==="dark"?"light":"dark";
  document.documentElement.dataset.theme=next;storage.setItem("allsp_theme",next);
};

function selectedIds(){
  try{return JSON.parse(storage.getItem("allsp_selected")||"[]")}catch{return[]}
}
function saveSelected(ids){storage.setItem("allsp_selected",JSON.stringify(ids.slice(0,3)))}
function toggleSelected(id){
  let ids=selectedIds();
  if(ids.includes(id)) ids=ids.filter(x=>x!==id);
  else{
    if(ids.length>=3){alert("Tu peux sélectionner au maximum trois spécialités.");return}
    ids.push(id);
  }
  saveSelected(ids);renderAll();
}
function isDone(sid,i){return storage.getItem("allsp_done_"+chapterKey(sid,i))==="1"}
function setDone(sid,i,val){
  storage.setItem("allsp_done_"+chapterKey(sid,i),val?"1":"0");updateProgress();renderMyPath();
}
function totalChapters(){return SUBJECTS.reduce((n,s)=>n+s.chapters.length,0)}
function completedChapters(){return SUBJECTS.reduce((n,s)=>n+s.chapters.filter((_,i)=>isDone(s.id,i)).length,0)}

function cardHtml(s){
  const chosen=selectedIds().includes(s.id);
  return `<article class="card subject-card" style="--subject:${s.color}">
    <button class="choice-btn ${chosen?"chosen":""}" data-choice="${s.id}" title="Ajouter à mes spécialités">${chosen?"✓":"★"}</button>
    <div class="subject-icon">${s.icon}</div><div class="subject-note">${esc(s.note)}</div>
    <h2>${esc(s.name)}</h2><p class="muted">${esc(s.description)}</p>
    <button class="btn subject open-subject" style="--subject:${s.color}" data-subject="${s.id}">Ouvrir les cours</button>
  </article>`;
}
function bindCards(root=document){
  $$("[data-choice]",root).forEach(b=>b.onclick=e=>{e.stopPropagation();toggleSelected(b.dataset.choice)});
  $$(".open-subject",root).forEach(b=>b.onclick=()=>openSubject(b.dataset.subject));
}
function renderHome(){
  $("#homeSubjectsBtn").onclick=()=>showPage("subjects");
  $("#homeMediaBtn").onclick=()=>showPage("media");
  $("#homeGamesBtn").onclick=()=>showPage("media");
  $("#homeAiBtn").onclick=()=>toggleAi(true);
}
function renderSubjects(filter=""){
  const q=filter.trim().toLowerCase();
  const list=SUBJECTS.filter(s=>{
    const text=[s.name,s.short,s.description,...s.chapters.flatMap(c=>[c.title,c.intro,...c.points])].join(" ").toLowerCase();
    return !q||text.includes(q);
  });
  $("#subjectCards").innerHTML=list.length?list.map(cardHtml).join(""):`<div class="empty">Aucune spécialité ou notion trouvée.</div>`;
  bindCards($("#subjectCards"));
}
$("#subjectSearch").oninput=e=>renderSubjects(e.target.value);
$("#clearSearch").onclick=()=>{$("#subjectSearch").value="";renderSubjects()};

function openSubject(id){
  const s=subjectById(id);if(!s)return;
  currentLearningContext={subject:s.name,chapter:"Vue générale",intro:s.description,points:[]};
  updateAiContext();
  $("#subjectContent").innerHTML=`<div class="hero subject-hero" style="--subject:${s.color}">
    <span class="pill">${esc(s.note)}</span><h1>${s.icon} ${esc(s.name)}</h1><p class="lead">${esc(s.description)}</p>
    <div class="pills"><span class="pill">${s.chapters.length} chapitres</span><span class="pill">Quiz pour chaque chapitre</span><span class="pill">Progression sauvegardée</span></div>
  </div>
  <div class="notice">${s.id==="llcer"?"Les axes précis diffèrent selon la langue ; utilise les méthodes communes et complète avec les thèmes donnés par ton professeur.":s.id==="bioeco"?"Cette spécialité est proposée uniquement dans les lycées agricoles.":"Ouvre un chapitre pour lire le cours, voir la méthode et lancer le quiz."}</div>
  <div>${s.chapters.map((c,i)=>chapterHtml(s,c,i)).join("")}</div>`;
  $$(".done-box",$("#subjectContent")).forEach(b=>b.onchange=()=>setDone(b.dataset.sid,Number(b.dataset.index),b.checked));
  $$(".chapter-quiz",$("#subjectContent")).forEach(b=>b.onclick=()=>startChapterQuiz(b.dataset.sid,Number(b.dataset.index)));
  $$(".chapter-ai",$("#subjectContent")).forEach(b=>b.onclick=()=>{
    const sub=subjectById(b.dataset.sid),c=sub.chapters[Number(b.dataset.index)];
    currentLearningContext={subject:sub.name,chapter:c.title,intro:c.intro,points:c.points};updateAiContext();toggleAi(true);
  });
  $$(".reveal-game",$("#subjectContent")).forEach(b=>b.onclick=()=>{
    const box=b.parentElement.querySelector(".game-answer");box.textContent=b.dataset.answer;box.classList.remove("hidden");
  });
  $$(".load-video",$("#subjectContent")).forEach(b=>b.onclick=()=>loadChapterVideo(b.dataset.videoKey));
  $$(".chapter",$("#subjectContent")).forEach((d,idx)=>d.addEventListener("toggle",()=>{
    if(!d.open)return;
    $$(".chapter",$("#subjectContent")).forEach(other=>{if(other!==d)other.open=false});
    const c=s.chapters[idx];
    currentLearningContext={subject:s.name,chapter:c.title,intro:c.intro,points:c.points};
    updateAiContext();
  }));
  restoreChapterVideos();
  showPage("subjectView");
}
