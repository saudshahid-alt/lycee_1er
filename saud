let mysteryNumber=0,mysteryTries=0,mysteryLow=1,mysteryHigh=100;
function resetMystery(){
  mysteryNumber=Math.floor(Math.random()*100)+1;mysteryTries=0;mysteryLow=1;mysteryHigh=100;
  $("#mysteryDisplay").textContent="1 à 100";$("#mysteryLog").textContent="Commence idéalement par 50.";$("#mysteryGuess").value="";
}
function tryMystery(){
  const g=Number($("#mysteryGuess").value);
  if(!Number.isInteger(g)||g<1||g>100){$("#mysteryLog").textContent="Entre un entier entre 1 et 100.";return}
  mysteryTries++;
  if(g===mysteryNumber){$("#mysteryLog").textContent=`Trouvé en ${mysteryTries} essai(s) ! Une stratégie dichotomique demande au maximum 7 essais.`;$("#mysteryDisplay").textContent="🎉 "+g;return}
  if(g<mysteryNumber){mysteryLow=Math.max(mysteryLow,g+1);$("#mysteryLog").textContent="C’est plus grand."}
  else{mysteryHigh=Math.min(mysteryHigh,g-1);$("#mysteryLog").textContent="C’est plus petit."}
  $("#mysteryDisplay").textContent=`${mysteryLow} à ${mysteryHigh}`;
}
