<script>
"use strict";
const SUBJECTS=[{"id":"arts","name":"Arts","short":"Arts","icon":"🎨","color":"#7b4cc9","note":"7 disciplines possibles","description":"Pratique, création, culture et analyse dans l’une des sept disciplines artistiques.","chapters":[{"title":"Arts plastiques","intro":"La pratique plastique interroge la représentation, la matière, la fabrication, l’espace, la présentation et la réception de l’œuvre.","points":["Représenter ne signifie pas seulement imiter : cadrage, déformation et écart produisent du sens.","Les matériaux, les gestes, la couleur et le support déterminent la matérialité de l’œuvre.","Le dispositif d’exposition modifie la relation au lieu, au corps et au spectateur.","Le carnet de pratique conserve recherches, essais, références, erreurs et décisions."],"method":"Pour analyser une production : identifier l’intention, décrire les choix visibles, expliquer leurs effets, puis les relier à des références.","example":"Une projection monumentale et une petite image encadrée peuvent montrer le même motif, mais elles n’engagent pas le corps du spectateur de la même manière."},{"title":"Cinéma-audiovisuel","intro":"Le cinéma construit du sens par le plan, le cadre, la lumière, le son, le mouvement et le montage.","points":["Un plan est une prise continue entre deux coupes.","Le montage organise la durée, le rythme et les relations entre les plans.","Le champ, le hors-champ et le point de vue orientent l’attention du spectateur.","L’écriture d’un projet passe par synopsis, scénario, découpage et réalisation."],"method":"Pour analyser une séquence : situer la scène, décrire plans et sons, étudier le montage, puis interpréter l’effet produit.","example":"Un gros plan peut isoler une émotion ; un plan d’ensemble replace le personnage dans son environnement."},{"title":"Danse","intro":"La danse articule corps, espace, temps, énergie, intention et relation aux autres.","points":["Le mouvement peut être décrit par ses appuis, directions, niveaux et qualités.","La composition chorégraphique organise répétitions, contrastes, unissons et décalages.","L’interprétation engage présence, précision et intention.","L’analyse mobilise traces vidéo, contexte, musique, scénographie et réception."],"method":"Observer une phrase dansée : relever trajectoires, rythme, dynamiques, relations entre danseurs et choix scéniques.","example":"Le même geste exécuté lentement, avec tension ou relâchement, change totalement sa signification."},{"title":"Histoire des arts","intro":"L’histoire des arts étudie les œuvres dans leurs contextes, leurs usages, leurs circulations et leurs réceptions.","points":["Une œuvre doit être identifiée, décrite, analysée et contextualisée.","Les arts dialoguent avec les pouvoirs, les croyances, les sciences et les sociétés.","Les techniques et les lieux de présentation influencent les formes artistiques.","La comparaison permet de distinguer continuités, ruptures et réemplois."],"method":"Construire un commentaire : problématique, observations précises, contexte, interprétation et comparaison argumentée.","example":"Comparer deux monuments ne consiste pas à dresser une liste : il faut choisir un axe, par exemple la mise en scène du pouvoir."},{"title":"Musique","intro":"La spécialité associe pratique, écoute, création, interprétation et culture musicale.","points":["Le langage musical organise hauteur, durée, timbre, intensité et espace.","Une œuvre peut être comprise par sa forme, ses motifs, son instrumentation et son contexte.","L’interprétation propose des choix de tempo, phrasé, articulation et équilibre.","Les technologies permettent enregistrer, transformer, mixer et diffuser le son."],"method":"Pour commenter une écoute : identifier les paramètres saillants, suivre la forme, comparer les sections et relier les choix au projet expressif.","example":"Une même mélodie change de caractère selon le tempo, l’instrumentation et les nuances."},{"title":"Théâtre","intro":"Le théâtre associe texte, jeu, espace, corps, voix, scénographie et relation au public.","points":["Le texte théâtral contient paroles et indications scéniques, mais la représentation constitue une nouvelle interprétation.","Le jeu travaille présence, écoute, adresse, rythme et intention.","La mise en scène organise espace, lumière, costumes, objets et sons.","Le spectateur produit du sens à partir du dispositif et des choix de représentation."],"method":"Analyser une scène : situation dramatique, enjeux, jeu, espace, rythme, objets, lumière et rapport au public.","example":"Une réplique dite face au partenaire ou directement au public ne produit pas la même relation."},{"title":"Arts du cirque","intro":"Les arts du cirque combinent prouesse, composition, risque maîtrisé, présence, agrès et dramaturgie.","points":["La technique corporelle est mise au service d’une intention artistique.","Le risque réel ou suggéré crée une tension avec le public.","L’espace, la musique, les objets et les partenaires structurent le numéro.","La sécurité repose sur préparation, répétition, parade et connaissance du matériel."],"method":"Analyser un numéro : identifier l’agrès, les contraintes, les figures, le rythme, le risque, la dramaturgie et le rapport au public.","example":"La répétition volontaire d’une chute simulée peut transformer une difficulté technique en motif comique."}]},{"id":"bioeco","name":"Biologie-écologie","short":"Bio-écologie","icon":"🌿","color":"#3c8b57","note":"Lycées agricoles uniquement","description":"Fonctionnement du vivant, biodiversité, écosystèmes, santé et démarche de terrain.","chapters":[{"title":"Organisation du vivant","intro":"Les systèmes vivants sont organisés de la molécule à l’écosystème et échangent matière, énergie et information.","points":["La cellule est l’unité structurale et fonctionnelle du vivant.","Les tissus et organes assurent des fonctions coordonnées.","Le métabolisme regroupe les transformations chimiques de l’organisme.","Les régulations maintiennent des conditions internes compatibles avec la vie."],"method":"Relier chaque niveau d’organisation à la fonction étudiée et utiliser des observations microscopiques ou expérimentales.","example":"Une feuille associe cellules chlorophylliennes, tissus conducteurs et stomates pour produire et échanger de la matière."},{"title":"Génétique, reproduction et évolution","intro":"L’information génétique se transmet, varie et contribue à la diversité des individus et des populations.","points":["L’ADN porte l’information génétique.","La reproduction sexuée crée de nouvelles combinaisons d’allèles.","Les mutations introduisent de nouvelles variations.","Sélection, dérive et migrations modifient les fréquences au cours du temps."],"method":"Distinguer variation individuelle, transmission héréditaire et évolution d’une population.","example":"Un caractère avantageux dans un milieu peut devenir plus fréquent si les individus qui le portent se reproduisent davantage."},{"title":"Écosystèmes et biodiversité","intro":"Un écosystème associe une communauté d’êtres vivants à son milieu physique et aux interactions qui les relient.","points":["Réseaux trophiques et cycles de matière structurent les écosystèmes.","La biodiversité s’étudie aux niveaux génétique, spécifique et écosystémique.","Les perturbations peuvent modifier la résilience d’un milieu.","Les activités humaines transforment habitats, ressources et équilibres."],"method":"Décrire le système, identifier flux et interactions, puis discuter pressions, indicateurs et capacité de restauration.","example":"La disparition d’un prédateur peut entraîner une augmentation de ses proies puis une forte pression sur la végétation."},{"title":"Santé et environnement","intro":"La santé dépend de facteurs biologiques, environnementaux, sociaux et comportementaux.","points":["Agents infectieux, immunité et prévention sont liés.","Alimentation, activité et environnement influencent le fonctionnement de l’organisme.","Les contaminants peuvent circuler et s’accumuler dans les chaînes alimentaires.","L’évaluation d’un risque distingue danger, exposition et vulnérabilité."],"method":"Analyser une question de santé avec des données, comparer les risques et justifier des mesures de prévention.","example":"Une substance toxique peut être peu risquée en l’absence d’exposition, mais devenir préoccupante si elle s’accumule dans l’organisme."},{"title":"Démarche scientifique de terrain","intro":"La biologie-écologie mobilise observations, échantillonnages, mesures, expérimentations et traitements de données.","points":["Un protocole doit préciser variables, témoins et répétitions.","L’échantillonnage doit être adapté à la question et au milieu.","Les résultats doivent être représentés avec unités et incertitudes.","Une conclusion répond à la question sans dépasser les données disponibles."],"method":"Question → hypothèse → protocole → collecte → traitement → interprétation → limites.","example":"Comparer deux prairies nécessite des surfaces d’échantillonnage similaires et plusieurs relevés, pas un seul point choisi au hasard."}]},{"id":"eppcs","name":"Éducation physique, pratiques et culture sportives","short":"EPPCS","icon":"🏅","color":"#e05c3c","note":"Pratique et théorie","description":"Performance, santé, technologie des activités physiques, culture et métiers du sport.","chapters":[{"title":"Pratique et performance","intro":"La performance résulte de ressources physiques, techniques, tactiques, mentales et collectives.","points":["L’entraînement repose sur régularité, progressivité et spécificité.","La technique rend l’action plus efficace et économique.","La tactique adapte les choix à l’environnement et aux adversaires.","L’analyse vidéo et les indicateurs permettent de réguler la pratique."],"method":"Fixer un objectif mesurable, diagnostiquer, planifier, pratiquer, recueillir des données et ajuster.","example":"Améliorer un temps de course ne dépend pas uniquement de courir plus vite : départ, allure et récupération comptent aussi."},{"title":"Pratique physique et santé","intro":"L’activité physique agit sur les systèmes cardiovasculaire, respiratoire, musculaire et psychologique.","points":["L’échauffement prépare progressivement l’organisme.","La récupération dépend du sommeil, de l’hydratation, de la nutrition et de la charge.","La prévention des blessures repose sur technique, progressivité et écoute des signaux.","La sédentarité constitue un facteur de risque distinct du manque de sport."],"method":"Évaluer une séance par intensité, durée, récupération, sensations et évolution des indicateurs.","example":"Une charge très élevée sans récupération suffisante peut diminuer la performance et augmenter le risque de blessure."},{"title":"Technologie des activités physiques","intro":"Chaque activité possède des contraintes, des règles, des principes d’efficacité et des moyens de mesure.","points":["Les forces, trajectoires et équilibres expliquent de nombreux gestes.","Le matériel modifie les possibilités et les performances.","Les règles structurent l’incertitude et l’équité de l’affrontement.","Les données doivent être interprétées dans le contexte de l’activité."],"method":"Décomposer le geste en phases, repérer les paramètres déterminants et tester une modification à la fois.","example":"En saut, la vitesse d’élan, l’angle d’impulsion et la coordination influencent la trajectoire."},{"title":"Culture et métiers du sport","intro":"Le sport est un fait social, économique, médiatique et politique, ainsi qu’un secteur professionnel diversifié.","points":["Les pratiques évoluent avec les sociétés et les technologies.","Le spectacle sportif mobilise médias, sponsors et organisations.","Les métiers concernent entraînement, santé, gestion, événementiel, recherche et équipement.","Éthique, inclusion, dopage et environnement sont des enjeux majeurs."],"method":"Pour étudier un enjeu : définir les acteurs, intérêts, règles, effets et controverses à partir de sources fiables.","example":"L’organisation d’un événement doit concilier sécurité, accès du public, impact environnemental et modèle économique."}]},{"id":"hggsp","name":"Histoire-géographie, géopolitique et sciences politiques","short":"HGGSP","icon":"🌍","color":"#315f9f","note":"5 thèmes officiels","description":"Comprendre les pouvoirs, territoires, frontières, informations et faits religieux.","chapters":[{"title":"Comprendre un régime politique : la démocratie","intro":"Le thème étudie les principes démocratiques, leurs formes, leurs avancées, leurs reculs et leurs transformations.","points":["Démocratie directe et représentative proposent des formes différentes de participation.","La séparation des pouvoirs limite leur concentration.","Les transitions démocratiques ne sont ni automatiques ni irréversibles.","L’Union européenne combine plusieurs niveaux de légitimité et de décision."],"method":"Comparer les institutions, les pratiques réelles, la participation et les libertés plutôt que se limiter au mot « démocratie ».","example":"Deux États peuvent organiser des élections mais différer fortement par la liberté de la presse ou l’indépendance de la justice."},{"title":"Analyser les dynamiques des puissances internationales","intro":"Une puissance est la capacité d’un acteur à agir sur les autres et sur l’organisation du monde.","points":["La puissance repose sur des ressources militaires, économiques, diplomatiques, culturelles et technologiques.","Hard power, soft power et smart power sont complémentaires.","Les puissances connaissent ascensions, transformations et déclins.","Le numérique, les langues et les réseaux renouvellent l’influence."],"method":"Identifier les attributs, les instruments, les échelles, les limites et les réactions des autres acteurs.","example":"Une plateforme numérique peut diffuser des normes culturelles tout en créant une dépendance technologique."},{"title":"Étudier les divisions politiques du monde : les frontières","intro":"Les frontières séparent, filtrent, protègent, organisent et peuvent aussi devenir des interfaces.","points":["Le tracé d’une frontière résulte d’un rapport de force et d’une histoire.","Certaines frontières sont ouvertes, contrôlées, militarisées ou contestées.","Les espaces maritimes étendent la question des limites et des ressources.","Les organisations régionales peuvent atténuer certaines frontières sans les supprimer."],"method":"Étudier le tracé, les acteurs, les usages, les flux, les conflits et les effets sur les populations.","example":"Une frontière peut être très ouverte aux marchandises mais difficile à franchir pour certaines personnes."},{"title":"S’informer : un regard critique sur les sources et modes de communication","intro":"L’information dépend de producteurs, de techniques, de modèles économiques et de rapports de pouvoir.","points":["La presse, la radio, la télévision et le numérique ont transformé la circulation de l’information.","Une source doit être identifiée, datée, contextualisée et confrontée.","Les algorithmes et les réseaux sociaux modifient la visibilité des contenus.","Propagande, désinformation et liberté de la presse sont des enjeux politiques."],"method":"Questionner auteur, date, support, objectif, preuves, public et sources concurrentes.","example":"Une image authentique peut désinformer si elle est sortie de son contexte ou associée à une fausse légende."},{"title":"Analyser les relations entre États et religions","intro":"Les rapports entre pouvoir politique et religions varient selon les périodes, les États et les sociétés.","points":["La sécularisation désigne une diminution de l’emprise religieuse sur certains domaines.","La laïcité organise la relation entre l’État, les cultes et les libertés.","Les religions peuvent être des ressources d’identité, de mobilisation ou de diplomatie.","Les conflits présentés comme religieux ont souvent plusieurs dimensions."],"method":"Distinguer institutions, croyances, pratiques, acteurs politiques et contextes historiques.","example":"Un conflit peut mobiliser des symboles religieux tout en portant sur le territoire, les ressources et le pouvoir."}]},{"id":"hlp","name":"Humanités, littérature et philosophie","short":"HLP","icon":"🗣️","color":"#8a4b65","note":"Littérature + philosophie","description":"Étudier les pouvoirs de la parole et les représentations du monde.","chapters":[{"title":"Les pouvoirs de la parole","intro":"Ce premier ensemble étudie l’art de parler, l’autorité de la parole et les séductions du langage de l’Antiquité à l’époque classique.","points":["La rhétorique organise invention, disposition, style, mémoire et action.","Une parole peut convaincre par les raisons, persuader par les émotions ou construire la confiance.","L’autorité dépend de la position du locuteur, du contexte et de la reconnaissance du public.","La séduction du langage peut éclairer, émouvoir ou manipuler."],"method":"Dans un texte ou un discours : identifier situation, thèse, destinataire, arguments, procédés et effets.","example":"Une même affirmation n’a pas la même force si elle est prononcée par un témoin, un expert ou une institution."},{"title":"Les représentations du monde","intro":"Ce second ensemble étudie les découvertes, la pluralité des cultures et la relation de l’être humain à l’animal.","points":["Les grandes découvertes modifient cartes, savoirs et visions de l’humanité.","Décrire une autre culture révèle aussi les catégories de l’observateur.","L’altérité peut produire curiosité, comparaison, domination ou remise en question.","La frontière entre humanité et animalité est philosophique, scientifique et littéraire."],"method":"Comparer les représentations, repérer le point de vue et discuter les présupposés du texte.","example":"Un récit de voyage renseigne sur le lieu décrit, mais aussi sur les normes et les attentes du voyageur."}]},{"id":"llcer","name":"Langues, littératures et cultures étrangères et régionales","short":"LLCER","icon":"🗺️","color":"#3a7f9b","note":"Langues et parcours variés","description":"Approfondir une langue par les œuvres, les sociétés, les médias, la traduction et l’oral.","chapters":[{"title":"Compréhension et expression approfondies","intro":"La spécialité vise une maîtrise plus précise de la langue à l’écrit et à l’oral.","points":["Comprendre l’explicite, l’implicite, le ton et le point de vue.","Construire une argumentation structurée et nuancée.","Mobiliser vocabulaire, grammaire et connecteurs avec précision.","Adapter le registre à la situation et au destinataire."],"method":"Repérer la consigne, sélectionner les informations, organiser une réponse, justifier par le document et relire la langue.","example":"Résumer un article ne consiste pas à traduire chaque phrase : il faut hiérarchiser les idées."},{"title":"Littérature et arts","intro":"Les œuvres littéraires et artistiques permettent d’étudier imaginaires, identités, relations et sociétés.","points":["Le narrateur, le point de vue et la structure influencent la lecture.","Les genres et les formes répondent à des conventions historiques.","Une adaptation transforme l’œuvre source par un nouveau médium.","Les figures de style produisent des effets qu’il faut interpréter."],"method":"Présenter l’extrait, analyser forme et sens, puis le relier à l’œuvre, au thème et au contexte culturel.","example":"Une adaptation cinématographique peut supprimer le narrateur mais utiliser cadrage et musique pour produire un effet équivalent."},{"title":"Civilisation, sociétés et médias","intro":"Les documents éclairent l’histoire, les institutions, les identités et les débats des espaces linguistiques étudiés.","points":["Un document culturel est situé dans un espace et une époque.","Les concepts ne se traduisent pas toujours exactement d’une société à l’autre.","Les médias sélectionnent et mettent en scène l’actualité.","Il faut confronter plusieurs points de vue et types de sources."],"method":"Identifier contexte, acteurs, enjeux, vocabulaire culturel et limites du document.","example":"Deux journaux peuvent rapporter le même événement avec des titres et des images qui orientent différemment la lecture."},{"title":"Traduction et médiation","intro":"Traduire consiste à reconstruire du sens dans une autre langue, pas à remplacer mécaniquement chaque mot.","points":["Le contexte détermine le sens d’un mot polysémique.","Les expressions idiomatiques demandent une équivalence.","La syntaxe et le registre doivent rester naturels dans la langue d’arrivée.","La médiation explique un contenu à un public qui ne dispose pas des mêmes repères."],"method":"Comprendre le passage entier, repérer les difficultés, proposer plusieurs solutions, choisir et relire l’effet global.","example":"Une traduction littérale d’une expression peut être correcte mot à mot mais incompréhensible culturellement."},{"title":"Dossier, synthèse et oral","intro":"Le dossier met en relation plusieurs documents autour d’une question.","points":["Une problématique organise la sélection des idées.","La synthèse compare les documents au lieu de les résumer séparément.","Les exemples servent une démonstration.","À l’oral, voix, rythme, regard et gestion du temps soutiennent le contenu."],"method":"Problématique → plan comparatif → références précises → transitions → conclusion répondant à la question.","example":"Un bon axe peut opposer deux visions d’un même mythe dans un roman, une affiche et un discours."},{"title":"Parcours proposés selon la langue","intro":"Les thèmes exacts varient selon la langue ou le parcours choisi : anglais, anglais monde contemporain, allemand, espagnol, italien, portugais et langues régionales.","points":["Chaque programme articule deux grands thèmes de première et des axes d’étude.","Les œuvres intégrales et documents sont étudiés dans la langue cible.","Les contextes historiques et culturels sont propres aux espaces concernés.","Le professeur choisit des objets d’étude conformes au programme de la langue."],"method":"Dans le site, utiliser les quatre chapitres de méthode pour toutes les langues, puis compléter avec les thèmes indiqués par le professeur et le Bulletin officiel.","example":"En anglais littérature, l’étude peut privilégier imaginaires et rencontres ; en anglais monde contemporain, les dossiers sont davantage ancrés dans l’actualité et les sociétés."}]},{"id":"llca","name":"Littérature et langues et cultures de l’Antiquité","short":"LLCA","icon":"🏛️","color":"#9a7134","note":"Latin ou grec","description":"Langue, littérature, histoire et réception des cultures grecque et romaine.","chapters":[{"title":"Langue et traduction","intro":"L’étude du latin ou du grec associe morphologie, syntaxe, lexique, traduction et commentaire.","points":["Les formes indiquent fonctions et relations dans la phrase.","La traduction exige de repérer verbes, propositions et groupes.","L’étymologie éclaire le vocabulaire français et scientifique.","Une traduction est un choix interprétatif argumenté."],"method":"Repérer les verbes, identifier les propositions, analyser les cas, construire le sens puis rédiger un français naturel.","example":"Deux traductions peuvent être différentes tout en respectant le texte si elles justifient les nuances."},{"title":"La cité entre réalités et utopies","intro":"La cité antique organise institutions, citoyenneté, espace public et représentations d’un ordre idéal.","points":["La citoyenneté antique est limitée et dépend du statut.","Les institutions répartissent assemblées, magistratures et conseils.","La cité idéale permet de critiquer les sociétés réelles.","Architecture et rituels donnent une forme visible à la communauté."],"method":"Comparer le modèle politique présenté, les citoyens inclus ou exclus et l’écart entre idéal et réalité.","example":"Athènes valorise la participation des citoyens, mais exclut femmes, esclaves et étrangers de la citoyenneté."},{"title":"Justice des dieux, justice des hommes","intro":"Textes et mythes confrontent lois divines, lois humaines, vengeance, procès et responsabilité.","points":["La justice peut être familiale, civique ou divine.","La tragédie met souvent en conflit des obligations légitimes.","Le procès transforme la vengeance privée en jugement public.","La faute, l’intention et le destin interrogent la responsabilité."],"method":"Identifier les normes en conflit, les autorités invoquées et les conséquences du choix du personnage.","example":"Antigone oppose devoir familial et loi de la cité, sans que le conflit se réduise à une opposition simple entre bien et mal."},{"title":"Amour, Amours","intro":"La littérature antique explore désir, mariage, fidélité, passion, amitié et pouvoir d’Éros.","points":["L’amour peut être force créatrice, maladie, domination ou initiation.","Les genres construisent des voix amoureuses différentes.","Les normes sociales encadrent unions et comportements.","Les mythes amoureux sont sans cesse réécrits."],"method":"Étudier qui parle, à qui, dans quel genre et avec quelles images du désir.","example":"Le mythe d’Orphée et Eurydice peut être relu comme histoire de fidélité, de création ou d’impossibilité du retour."},{"title":"Méditerranée : conflits, influences et échanges","intro":"La Méditerranée antique est un espace de guerres, mobilités, commerces, colonisations et transferts culturels.","points":["Les peuples circulent avec techniques, langues, cultes et récits.","Les empires organisent et hiérarchisent les territoires.","Les identités se construisent par contacts et oppositions.","Les textes antiques représentent l’étranger selon des enjeux précis."],"method":"Localiser les routes et acteurs, distinguer conflit et échange, puis analyser les effets culturels.","example":"La conquête romaine impose une domination, mais favorise aussi des circulations et des hybridations religieuses ou artistiques."}]},{"id":"maths","name":"Mathématiques","short":"Maths","icon":"∑","color":"#244db3","note":"Nouveau programme rentrée 2026","description":"Algèbre, analyse, géométrie, probabilités, logique et programmation.","chapters":[{"title":"Logique, ensembles et automatismes","intro":"Les notations et raisonnements logiques traversent tout le programme.","points":["Appartenance, inclusion, intersection, réunion et complémentaire structurent les ensembles.","Implication, réciproque, contraposée et équivalence n’ont pas le même sens.","Un contre-exemple suffit à réfuter une proposition universelle.","Calcul littéral, pourcentages et lectures graphiques doivent devenir automatiques."],"method":"Avant de démontrer, identifier clairement hypothèses, conclusion et type de raisonnement.","example":"La réciproque de « si un entier est multiple de 4, alors il est pair » est fausse : 6 est pair sans être multiple de 4."},{"title":"Algorithmique, Python et listes","intro":"La programmation consolide variables, fonctions, conditions et boucles, avec la notion de liste.","points":["Une fonction transforme des entrées en résultat.","Une liste peut être générée, parcourue et modifiée.","Une boucle bornée répète un traitement sur un ensemble d’indices.","La programmation modulaire décompose un problème complexe."],"method":"Spécifier l’entrée et la sortie, écrire un cas simple, tester, puis généraliser.","example":"Une liste permet de stocker les premiers termes d’une suite et de rechercher le premier qui dépasse un seuil."},{"title":"Suites numériques","intro":"Les suites modélisent des évolutions à temps discret.","points":["Une suite peut être définie explicitement ou par récurrence.","Une suite arithmétique correspond à un accroissement constant.","Une suite géométrique correspond à un coefficient multiplicateur constant.","Le sens de variation et l’idée intuitive de limite décrivent le comportement."],"method":"Identifier le type d’évolution, écrire la relation, calculer les termes puis interpréter dans le contexte.","example":"Un capital augmenté de 3 % par an est modélisé par une suite géométrique de raison 1,03."},{"title":"Second degré","intro":"Les polynômes du second degré modélisent trajectoires, aires, coûts et optimisations.","points":["Les formes développée, factorisée et canonique répondent à des besoins différents.","Les racines permettent la factorisation et la résolution.","Le signe dépend du coefficient directeur dominant et des racines.","Le sommet donne un minimum ou un maximum."],"method":"Choisir la forme adaptée : développer pour comparer, factoriser pour résoudre, canonique pour étudier le sommet.","example":"Pour maximiser une aire modélisée par une parabole tournée vers le bas, on cherche l’abscisse du sommet."},{"title":"Dérivation et variations","intro":"Le nombre dérivé mesure le taux de variation instantané et la pente de la tangente.","points":["La dérivée d’une somme se calcule terme à terme.","Le signe de f′ détermine les variations de f.","Une tangente en a a pour pente f′(a).","Les extremums locaux apparaissent souvent lorsque f′ change de signe."],"method":"Calculer f′, étudier son signe, dresser le tableau de variations et répondre à la question posée.","example":"Si f′ est positive puis négative, la fonction atteint un maximum au changement de signe."},{"title":"Exponentielle et trigonométrie","intro":"L’exponentielle modélise des variations continues proportionnelles, tandis que la trigonométrie étudie les angles et phénomènes périodiques.","points":["La fonction exponentielle est positive et sa dérivée est elle-même.","e^(a+b)=e^a e^b permet les transformations.","Le cercle trigonométrique définit sinus et cosinus.","Les fonctions sinusoïdales modélisent des phénomènes périodiques."],"method":"Relier le contexte au modèle, contrôler les unités et interpréter paramètres, période et croissance.","example":"Un signal périodique peut être décrit par son amplitude, sa période et son décalage."},{"title":"Calcul vectoriel et produit scalaire","intro":"Les vecteurs décrivent directions et déplacements ; le produit scalaire mesure une relation angulaire.","points":["Coordonnées, somme et multiplication par un réel permettent les calculs vectoriels.","Le produit scalaire peut se calculer par coordonnées ou par les normes et l’angle.","Deux vecteurs sont orthogonaux si leur produit scalaire est nul.","Distances et projections se déduisent de ces outils."],"method":"Choisir une formule adaptée aux données : coordonnées disponibles ou longueurs et angle.","example":"Pour vérifier qu’un triangle est rectangle, on peut montrer que deux vecteurs de côtés ont un produit scalaire nul."},{"title":"Géométrie repérée","intro":"La géométrie repérée traduit des propriétés géométriques en équations.","points":["Une droite peut être décrite par un point et un vecteur directeur ou par une équation.","Le parallélisme correspond à des vecteurs colinéaires.","Les coordonnées permettent de calculer milieu et distance.","Les intersections se déterminent par résolution de systèmes."],"method":"Faire un schéma, traduire chaque condition en coordonnées, résoudre et vérifier géométriquement.","example":"L’intersection de deux droites se trouve en résolvant simultanément leurs équations."},{"title":"Probabilités conditionnelles, variables aléatoires et statistiques","intro":"Les probabilités modélisent l’incertitude et les variables aléatoires associent une valeur numérique aux issues.","points":["P(A∩B)=P(A)P_A(B).","L’indépendance signifie P(A∩B)=P(A)P(B).","L’espérance représente une valeur moyenne théorique.","Variance et écart-type décrivent la dispersion."],"method":"Définir événements et univers, utiliser tableau ou arbre, calculer puis interpréter sans confondre condition et intersection.","example":"Une espérance positive ne garantit pas un gain à chaque partie ; elle décrit la moyenne sur un grand nombre de répétitions."}]},{"id":"nsi","name":"Numérique et sciences informatiques","short":"NSI","icon":"{ }","color":"#16805d","note":"Python et informatique","description":"Données, programmation, algorithmique, Web, réseaux, architecture et systèmes.","chapters":[{"title":"Histoire de l’informatique","intro":"L’informatique résulte d’innovations successives : calcul automatique, programme, électronique, réseaux et Web.","points":["Babbage imagine une machine analytique et Ada Lovelace décrit un algorithme.","Turing formalise un modèle général du calcul.","Le programme enregistré place données et instructions en mémoire.","Internet est l’infrastructure ; le Web est un service utilisant cette infrastructure."],"method":"Associer chaque date ou personne à l’idée technique qu’elle introduit.","example":"Le Web utilise Internet, mais le courrier électronique utilise aussi Internet sans être le Web."},{"title":"Types et valeurs de base","intro":"Nombres, booléens et caractères sont représentés par des suites de bits.","points":["Le binaire utilise les puissances de 2 et l’hexadécimal seize symboles.","Le complément à deux code les entiers relatifs.","Les flottants représentent de nombreux réels de façon approchée.","Unicode associe des points de code aux caractères."],"method":"Pour convertir un binaire, additionner les puissances de 2 correspondant aux bits égaux à 1.","example":"1010₂ vaut 8 + 2 = 10."},{"title":"Types construits","intro":"Tuples, listes, tableaux et dictionnaires regroupent des valeurs selon des usages différents.","points":["Un tuple est ordonné et immuable.","Une liste est ordonnée et modifiable.","Un dictionnaire associe des clés uniques à des valeurs.","Deux variables peuvent référencer le même objet mutable."],"method":"Choisir la structure selon l’accès nécessaire : position, ordre, modification ou clé.","example":"Modifier une liste partagée par deux variables produit un effet visible depuis les deux noms."},{"title":"Données en tables","intro":"Les tables organisent des enregistrements en lignes et attributs en colonnes.","points":["CSV stocke des données séparées par un délimiteur.","Les valeurs importées doivent être contrôlées et converties.","Filtrer conserve des lignes ; trier les ordonne selon une clé.","Une jointure fusionne des tables grâce à un champ commun."],"method":"Valider les domaines, nettoyer, transformer, puis seulement analyser.","example":"Une colonne d’âge lue depuis CSV contient des chaînes : il faut les convertir avant une comparaison numérique."},{"title":"Web et interaction humain-machine","intro":"Le navigateur construit un DOM et JavaScript réagit aux événements et modifie la page.","points":["HTML structure et CSS présente.","Les événements déclenchent des fonctions.","Le client envoie une requête HTTP et le serveur répond.","HTTPS chiffre les échanges grâce à TLS."],"method":"Action utilisateur → événement → traitement → requête éventuelle → réponse → mise à jour du DOM.","example":"POST place des données dans le corps de la requête, mais seul HTTPS assure leur chiffrement pendant le transport."},{"title":"Architecture, réseaux et systèmes","intro":"Le processeur exécute des instructions, le système gère les ressources et les protocoles transportent les données.","points":["L’architecture de von Neumann associe processeur, mémoire, bus et entrées-sorties.","Les paquets transportent données et informations de contrôle.","TCP assure un transport fiable ; IP assure l’acheminement.","Le système d’exploitation gère processus, mémoire, fichiers et droits."],"method":"Suivre le chemin d’une donnée de l’application au réseau puis jusqu’au destinataire.","example":"Un paquet perdu peut être retransmis par TCP sans que l’utilisateur reconstruise lui-même le message."},{"title":"Langages et programmation","intro":"Un programme clair est découpé, spécifié, testé et documenté.","points":["Conditions et boucles contrôlent l’exécution.","Une fonction possède paramètres, résultat et variables locales.","Préconditions et postconditions décrivent le contrat.","Assertions et tests détectent les erreurs."],"method":"Écrire une fonction courte, définir les cas de test puis intégrer au programme.","example":"Tester seulement un cas ordinaire ne suffit pas : il faut aussi les listes vides, limites ou valeurs inhabituelles."},{"title":"Algorithmique","intro":"Les algorithmes sont comparés par leur correction, leur terminaison et leur coût.","points":["La recherche séquentielle parcourt les éléments un à un.","La dichotomie exige un tableau trié et élimine la moitié des candidats.","Sélection et insertion sont quadratiques dans le pire cas.","k plus proches voisins et algorithmes gloutons répondent à des problèmes de décision."],"method":"Identifier données, résultat, invariant, variant et ordre de grandeur du nombre d’opérations.","example":"Sur un million d’éléments triés, la dichotomie nécessite environ vingt étapes, pas un million."}]},{"id":"pc","name":"Physique-chimie","short":"Physique-Chimie","icon":"⚗️","color":"#3970c9","note":"Expérience et modélisation","description":"Matière, mouvements, énergie, ondes, signaux, mesures et incertitudes.","chapters":[{"title":"Mesure et incertitudes","intro":"Une mesure varie avec l’instrument, le protocole et les conditions expérimentales.","points":["Une série de mesures permet de calculer moyenne et dispersion.","Le type A utilise les statistiques ; le type B les caractéristiques du dispositif.","Le résultat doit comporter unité et chiffres significatifs cohérents.","La compatibilité avec une référence se discute avec l’incertitude."],"method":"Mesurer plusieurs fois, calculer, estimer l’incertitude, arrondir et comparer.","example":"L = (12,4 ± 0,2) cm indique un intervalle approximatif de 12,2 à 12,6 cm."},{"title":"Constitution et transformations de la matière","intro":"La quantité de matière relie les entités microscopiques aux masses et volumes mesurés.","points":["n=m/M et c=n/V sont des relations centrales.","Beer-Lambert relie absorbance et concentration dans son domaine de validité.","Une oxydo-réduction transfère des électrons.","Le tableau d’avancement identifie état final et réactif limitant."],"method":"Équilibrer l’équation, convertir en moles, organiser les données et vérifier les unités.","example":"Pour 18 g d’eau de masse molaire 18 g·mol⁻¹, n=1 mol."},{"title":"Mouvement et interactions","intro":"Les forces et champs expliquent les variations du vecteur vitesse.","points":["Gravitation et électrostatique décroissent avec le carré de la distance.","La pression est une force répartie sur une surface.","Le vecteur vitesse est tangent à la trajectoire.","La résultante des forces est reliée à la variation de vitesse."],"method":"Définir le système, choisir le référentiel, faire le bilan des forces puis relier au mouvement.","example":"Si les forces se compensent, un objet peut rester au repos ou se déplacer à vitesse constante."},{"title":"Énergie : conversions et transferts","intro":"Les bilans suivent les formes d’énergie, les travaux, les puissances et les pertes.","points":["P=UI et E=PΔt en électricité.","Ec=½mv² dépend du carré de la vitesse.","Le travail d’une force dépend de l’angle avec le déplacement.","Sans dissipation, l’énergie mécanique peut se conserver."],"method":"Choisir le système et les états initial/final, puis inventorier énergie reçue, utile, stockée et dissipée.","example":"Doubler une vitesse multiplie l’énergie cinétique par quatre."},{"title":"Ondes et signaux","intro":"Les ondes transportent de l’énergie et les signaux donnent accès à des informations.","points":["v=d/τ et v=λf décrivent propagation et périodicité.","f=1/T relie fréquence et période.","Une lentille convergente forme des images selon la position de l’objet.","L’énergie d’un photon vaut E=hf."],"method":"Identifier les grandeurs, convertir les unités et représenter la situation avant le calcul.","example":"Une onde de fréquence 500 Hz et de longueur d’onde 0,68 m se propage à 340 m·s⁻¹."}]},{"id":"svt","name":"Sciences de la vie et de la Terre","short":"SVT","icon":"🧬","color":"#3d9348","note":"Biologie et géologie","description":"Génétique, évolution, dynamique terrestre, écosystèmes, santé et immunité.","chapters":[{"title":"Transmission et variation du patrimoine génétique","intro":"La division cellulaire transmet l’information génétique tandis que mutations et reproduction produisent de la diversité.","points":["La mitose conserve le nombre et l’information des chromosomes.","La réplication de l’ADN précède la division.","Les mutations créent de nouveaux allèles.","Les cellules d’un organisme partagent le génome mais n’expriment pas les mêmes gènes."],"method":"Passer des observations cellulaires au modèle chromosomique puis au mécanisme moléculaire.","example":"Une mutation dans une cellule de peau n’est généralement pas transmise à la descendance."},{"title":"Expression du patrimoine génétique et enzymes","intro":"L’information portée par l’ADN est transcrite et traduite pour produire des protéines.","points":["La transcription fabrique un ARN à partir d’un gène.","La traduction associe codons et acides aminés.","Les protéines déterminent structures et fonctions cellulaires.","Les enzymes accélèrent des réactions avec une spécificité liée à leur structure."],"method":"Relier séquence d’ADN, ARN, séquence protéique et conséquence fonctionnelle.","example":"Une mutation peut modifier un acide aminé et altérer le fonctionnement d’une enzyme."},{"title":"Structure et dynamique interne de la Terre","intro":"Les données sismiques et géologiques révèlent la structure du globe et la mobilité des plaques.","points":["Les ondes sismiques changent de vitesse selon les matériaux.","La lithosphère rigide repose sur une asthénosphère plus ductile.","Les dorsales produisent de la lithosphère océanique.","La subduction recycle la lithosphère et provoque séismes et volcanisme."],"method":"Croiser cartes, profils sismiques, âge des roches et données thermiques pour construire un modèle.","example":"L’âge du plancher océanique augmente en s’éloignant d’une dorsale."},{"title":"Écosystèmes et services environnementaux","intro":"Les écosystèmes fonctionnent par interactions, flux de matière et dynamique des populations.","points":["Producteurs, consommateurs et décomposeurs forment des réseaux.","La matière est recyclée tandis que l’énergie se dissipe.","Les perturbations modifient les équilibres et la résilience.","Les écosystèmes fournissent des services d’approvisionnement, régulation et culture."],"method":"Définir le système, repérer interactions et flux, puis analyser l’effet d’une perturbation.","example":"Une haie peut fournir habitat, limiter l’érosion, stocker du carbone et favoriser la pollinisation."},{"title":"Variation génétique et santé","intro":"Des variations génétiques peuvent être neutres, avantageuses ou associées à des maladies.","points":["Une maladie peut être monogénique ou multifactorielle.","Prédisposition ne signifie pas certitude.","Cancer et résistance aux antibiotiques impliquent mutations et sélection.","Dépistage et conseil génétique posent des questions éthiques."],"method":"Distinguer génotype, phénotype, risque et influence de l’environnement.","example":"Porter un allèle de prédisposition augmente parfois un risque sans déterminer à lui seul la maladie."},{"title":"Fonctionnement du système immunitaire","intro":"L’immunité innée agit rapidement ; l’immunité adaptative est spécifique et possède une mémoire.","points":["Inflammation et phagocytose appartiennent à l’immunité innée.","Les lymphocytes reconnaissent des antigènes spécifiques.","Les anticorps sont produits par des cellules issues de lymphocytes B.","La vaccination crée une mémoire sans provoquer la maladie grave."],"method":"Identifier l’agent, la réponse innée, la réponse adaptative et la mémoire.","example":"Après un rappel vaccinal, la réponse est généralement plus rapide et plus intense."}]},{"id":"si","name":"Sciences de l’ingénieur","short":"SI","icon":"⚙️","color":"#5c667a","note":"Conception et systèmes","description":"Analyser, modéliser, simuler, concevoir et valider des produits innovants.","chapters":[{"title":"Analyser le besoin et les exigences","intro":"Un produit répond à un besoin dans un contexte d’usage, avec des contraintes mesurables.","points":["Le besoin se distingue de la solution technique.","Les parties prenantes ont des attentes parfois contradictoires.","Une exigence doit être vérifiable par un critère et un niveau.","Cycle de vie, sécurité, coût et environnement font partie de l’analyse."],"method":"Exprimer le besoin, identifier les acteurs, formaliser les exigences puis définir comment les vérifier.","example":"« Être léger » devient exploitable si l’exigence précise une masse maximale."},{"title":"Chaînes d’information et d’énergie","intro":"Les systèmes acquièrent, traitent et communiquent l’information tout en alimentant, distribuant, convertissant et transmettant l’énergie.","points":["Un capteur transforme une grandeur physique en information.","Le traitement prend une décision selon un programme.","Un actionneur transforme une énergie en action.","Les interfaces relient sous-systèmes et utilisateur."],"method":"Tracer les flux, nommer les fonctions et relier chaque composant à sa fonction.","example":"Un portail automatique détecte un véhicule, traite la commande, alimente le moteur et transmet le mouvement."},{"title":"Modélisation mécanique et énergétique","intro":"Les modèles représentent mouvements, forces, puissances et rendements avec des hypothèses explicites.","points":["Position, vitesse et accélération décrivent le mouvement.","Les actions mécaniques sont représentées par des forces et moments.","Puissance et énergie permettent les bilans.","Un modèle simplifie la réalité et possède un domaine de validité."],"method":"Isoler le système, choisir les hypothèses, écrire les relations, simuler puis comparer aux mesures.","example":"Négliger les frottements peut être acceptable à faible durée, mais fausser une prévision énergétique."},{"title":"Commande, programmation et simulation","intro":"La commande organise le comportement d’un système à partir d’entrées, d’états et de règles.","points":["Un algorithme peut être séquentiel, conditionnel ou événementiel.","Une boucle de retour compare consigne et mesure.","La simulation permet de tester avant le prototype.","Les données expérimentales servent à ajuster les paramètres."],"method":"Définir les états et transitions, programmer un modèle simple, tester les cas normaux et les défauts.","example":"Un thermostat compare la température mesurée à la consigne avant d’activer ou couper le chauffage."},{"title":"Conception, prototypage et validation","intro":"La conception explore plusieurs solutions, réalise un prototype et vérifie les performances.","points":["Les solutions sont comparées selon critères techniques, économiques et environnementaux.","CAO et fabrication numérique accélèrent les itérations.","Un protocole de test doit être reproductible.","L’écart entre simulation et mesure conduit à corriger modèle ou prototype."],"method":"Imaginer → sélectionner → modéliser → prototyper → mesurer → valider → améliorer.","example":"Un prototype imprimé en 3D peut valider l’ergonomie avant de choisir un matériau industriel."}]},{"id":"ses","name":"Sciences économiques et sociales","short":"SES","icon":"📊","color":"#9c563d","note":"Économie, sociologie, science politique","description":"Marchés, financement, monnaie, socialisation, opinion, vote, risques et entreprises.","chapters":[{"title":"Comment un marché concurrentiel fonctionne-t-il ?","intro":"Le marché coordonne offre et demande par les prix lorsque certaines conditions de concurrence sont réunies.","points":["La demande décroît généralement avec le prix, l’offre augmente.","L’équilibre détermine prix et quantité échangée.","Le surplus mesure les gains à l’échange.","Une taxe ou subvention modifie prix, quantité et répartition du surplus."],"method":"Tracer offre et demande, repérer l’équilibre, puis analyser le déplacement d’une courbe.","example":"Une hausse du coût de production déplace l’offre et tend à augmenter le prix d’équilibre."},{"title":"Comment 