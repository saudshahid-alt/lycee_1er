function buildQuestion(s,c,index){
  const others=shuffle(s.chapters.filter((_,i)=>i!==index).flatMap(x=>x.points)).slice(0,3);
  const correct=c.points[0];
  const opts=shuffle([correct,...others]);
  return {
    q:`Quelle affirmation correspond au chapitre « ${c.title} » ?`,
    options:opts,answer:opts.indexOf(correct),
    explain:correct
  };
}
function buildMethodQuestion(s,c,index){
  const otherMethods=shuffle(s.chapters.filter((_,i)=>i!==index).map(x=>x.method)).slice(0,3);
  const opts=shuffle([c.method,...otherMethods]);
  return {
    q:`Quelle méthode est la plus adaptée à « ${c.title} » ?`,
    options:opts,answer:opts.indexOf(c.method),
    explain:c.method
  };
}
function buildExampleQuestion(s,c,index){
  const others=shuffle(s.chapters.filter((_,i)=>i!==index).map(x=>x.example)).slice(0,3);
  const opts=shuffle([c.example,...others]);
  return {
    q:`Quel exemple illustre le mieux « ${c.title} » ?`,
    options:opts,answer:opts.indexOf(c.example),
    explain:c.example
  };
}
function questionsForChapter(s,i){
  const c=s.chapters[i];
